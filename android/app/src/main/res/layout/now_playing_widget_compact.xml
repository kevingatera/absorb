<?xml version="1.0" encoding="utf-8"?>
<!-- Compact 4x1 now-playing widget -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_outer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="5dp"
    android:paddingEnd="5dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <!-- The card -->
    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_background"
        android:clipToOutline="true"
        android:orientation="horizontal">

        <!-- Cover art: full height of card, square -->
        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Cover art" />

        <!-- Right side: title/author on top, controls centered below -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- Title -->
            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Absorb"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium" />

            <!-- Author -->
            <TextView
                android:id="@+id/widget_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Not playing"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Equal spacers above and below controls to center them -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Controls spread across full width -->
            <LinearLayout
                android:id="@+id/widget_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <FrameLayout
                    android:id="@+id/widget_skip_back"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="Skip backward">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_widget_skip_back"
                        android:scaleType="centerInside" />
                    <TextView
                        android:id="@+id/widget_skip_back_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="2dp"
                        android:text="10"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

                <ImageButton
                    android:id="@+id/widget_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_widget_play_dark"
                    android:background="@drawable/widget_play_btn_bg"
                    android:contentDescription="Play or pause"
                    android:scaleType="centerInside" />

                <FrameLayout
                    android:id="@+id/widget_skip_forward"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="Skip forward">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_widget_skip_forward"
                        android:scaleType="centerInside" />
                    <TextView
                        android:id="@+id/widget_skip_forward_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="2dp"
                        android:text="30"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </FrameLayout>

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
